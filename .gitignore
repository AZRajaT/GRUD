# Root .gitignore for GRUD project

# Node modules in any subdirectory
**/node_modules/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# IDE
.idea/
.vscode/
*.code-workspace

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Temporary files
temp/
tmp/
*.tmp

# Cache
.cache/

# System folders
.Trash/
$RECYCLE.BIN/
